## 1.3	系统优化

### 内核升级

```
#升级除内核之外的包
yum update -y --exclude=kernel*
reboot
#下载内核升级包
wget https://dl.lamp.sh/kernel/el7/kernel-ml-5.10.222-1.el7.x86_64.rpm
wget https://dl.lamp.sh/kernel/el7/kernel-ml-devel-5.10.222-1.el7.x86_64.rpm
#将已下载的内核包发送到其它服务器
for host in kube-node01 kube-node02 kube-node03; do scp -r kernel $host:~/ ; done 
#安装内核包
cd ~/kernel/
yum localinstall -y kernel-ml-*
#查看系统中可用的内核
awk -F\' '$1=="menuentry " {print  $2}' /etc/grub2.cfg
#修改默认启用的内核版本
grub2-set-default 0
grub2-mkconfig -o /etc/grub2.cfg
grubby --args="user.namespace.enable=1" --update-kernel="$(grubby --default-kernel)"
grubby --default-kernel
#重启服务器
reboot
uname -a
```



