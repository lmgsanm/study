yum install -y docker-ce-20.10.24-3.el7 docker-ce-cli-20.10.24-3.el7 containerd.io-1.4.13-3.1.el7

mkdir -p /etc/docker
cat > /etc/docker/daemon.json  << EOF
{
  "registry-mirrors": [
    "https://mciwm180.mirror.aliyuncs.com",
